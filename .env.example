# Environment Configuration
# Copy this to .env and update values as needed

# Database
DATABASE_URL=sqlite:///./cost_leak_killer.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/cost_leak_killer

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# ML Configuration
ISOLATION_FOREST_CONTAMINATION=0.1
MIN_SAMPLES_FOR_ML=10

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# Financial Configuration
DEFAULT_CURRENCY=USD
SAVINGS_MULTIPLIER=0.3

# LLM Configuration (optional - for future integration)
LLM_API_KEY=
LLM_MODEL=gpt-3.5-turbo

# Frontend
FRONTEND_URL=http://localhost:8501

# Logging
LOG_LEVEL=INFO

# Email Configuration (for action execution)
SMTP_SERVER=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@costleakkiller.local
